---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Terms of Service — Pink Payroll">

  <!-- ===== HEADER ===== -->
  <section class="bg-brand-black text-white">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-4">Legal</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-3">Terms of Service</h1>
      <p class="text-gray-400 text-sm">Last Updated: March 8, 2026</p>
    </div>
  </section>

  <!-- ===== CONTENT ===== -->
  <section class="max-w-3xl mx-auto px-6 py-16">

    <p class="text-brand-gray text-lg leading-relaxed mb-10">
      Welcome to Pink Payroll. These Terms of Service ("Terms") govern your access to and use of the services provided by Pink Payroll ("we," "us," or "our"), including our website, payroll processing, and HR support tools (collectively, the "Services"). By using our Services, you agree to be bound by these Terms.
    </p>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 1 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">1. Description of Services</h2>
      <p class="text-brand-gray leading-relaxed">
        Pink Payroll provides boutique payroll processing, tax filing assistance, and HR resource tools. We are a service provider and do not provide legal, investment, or certified accounting advice.
      </p>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 2 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">2. User Responsibilities & Data Accuracy</h2>
      <p class="text-brand-gray leading-relaxed mb-5">
        You are solely responsible for the accuracy, timeliness, and completeness of all data submitted to us (including employee hours, tax IDs, and bank account information).
      </p>
      <ul class="space-y-3">
        {[
          { label: 'The "Final Review"', text: 'You agree to review all payroll previews and reports for errors prior to final submission.' },
          { label: 'Late Submissions', text: 'We are not liable for penalties, interest, or late fees resulting from data submitted after our established processing deadlines.' },
        ].map(({ label, text }) => (
          <li class="flex gap-3">
            <span class="mt-1 w-4 h-4 flex-shrink-0 rounded-full bg-brand-light-gray flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-brand-gray" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed"><strong class="text-brand-black">{label}:</strong> {text}</p>
          </li>
        ))}
      </ul>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 3 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">3. Compliance with State & Federal Laws</h2>
      <ul class="space-y-3">
        {[
          { label: 'Multi-State Labor Compliance', text: 'You agree to comply with the specific labor codes of the state(s) in which your employees reside, including but not limited to meal and rest break laws, overtime calculations, and wage statement transparency.' },
          { label: 'Governing Law', text: 'All contractual disputes shall be governed by the laws of the State of Wyoming, without regard to conflict of law principles.' },
        ].map(({ label, text }) => (
          <li class="flex gap-3">
            <span class="mt-1 w-4 h-4 flex-shrink-0 rounded-full bg-brand-light-gray flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-brand-gray" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed"><strong class="text-brand-black">{label}:</strong> {text}</p>
          </li>
        ))}
      </ul>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 4 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">4. Limitation of Liability & Indemnification</h2>
      <p class="text-brand-gray leading-relaxed">
        To the maximum extent permitted by law, Pink Payroll's total liability for any claim arising out of the Services shall not exceed the total fees paid by you to us during the six (6) months immediately preceding the event giving rise to the claim. You agree to indemnify and hold harmless Pink Payroll from any claims resulting from your failure to comply with local labor laws or the submission of inaccurate data.
      </p>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 5 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">5. Security & Access</h2>
      <p class="text-brand-gray leading-relaxed">
        You are responsible for maintaining the confidentiality of your login credentials for the iSolved© portal and any other Services. You must notify us immediately of any unauthorized access to your account.
      </p>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 6 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">6. Termination & Survival</h2>
      <p class="text-brand-gray leading-relaxed">
        Either party may terminate the Service agreement upon 30 days' written notice. Provisions regarding liability, indemnification, and governing law shall survive the termination of this agreement.
      </p>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Section 7 -->
    <div class="mb-10">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">7. Savings Clause</h2>
      <p class="text-brand-gray leading-relaxed">
        If any provision of these Terms is found by a court of competent jurisdiction to be invalid or unenforceable, the remaining provisions shall remain in full force and effect.
      </p>
    </div>

    <hr class="border-brand-light-gray mb-10" />

    <!-- Contact -->
    <div class="bg-brand-light-gray/40 border border-brand-light-gray rounded-2xl p-8">
      <h2 class="text-xl font-extrabold text-brand-black mb-4">Contact Us</h2>
      <p class="text-brand-gray leading-relaxed mb-5">
        If you have questions regarding these Terms, please contact us at:
      </p>
      <div class="space-y-1 text-sm">
        <p class="font-bold text-brand-black">Pink Payroll</p>
        <p><a href="tel:8009950308" class="text-pink hover:underline">(800) 995-0308</a></p>
        <p class="text-brand-gray">4010 Morena Blvd, #220, San Diego, CA 92117</p>
      </div>
    </div>

  </section>

</Layout>
