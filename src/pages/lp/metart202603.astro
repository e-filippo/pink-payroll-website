---
// metart202603 — Meta Retargeting | March 2026
import LandingLayout from '../../layouts/LandingLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/hero-image.png';
import bizGuyImage from '../../assets/coffee-clique-biz-guy.png';
---

<LandingLayout title="Thinking of Switching? Pink Payroll Does the Heavy Lifting.">

  <style>
    @keyframes rock {
      0%   { transform: rotate(-4deg); }
      50%  { transform: rotate(4deg); }
      100% { transform: rotate(-4deg); }
    }
    .rock {
      display: inline-block;
      animation: rock 1.8s ease-in-out infinite;
      transform-origin: center bottom;
    }
  </style>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-6 pb-4">

    <!-- Rocking banner: centered above the two-column layout -->
    <div class="text-center mb-6">
      <div class="rock inline-block bg-pink text-white rounded-2xl px-10 py-4 shadow-lg">
        <p class="text-xs font-bold uppercase tracking-widest opacity-80 mb-1">Limited Time Offer</p>
        <p class="text-5xl font-extrabold leading-none mb-2">3 Months Free</p>
        <p class="text-xs font-bold uppercase tracking-widest opacity-80">&#9733; For California Small Businesses</p>
      </div>
    </div>

    <!-- Two-column: headline left / image right, ~15% gap between them -->
    <div class="flex flex-col lg:flex-row items-stretch gap-[8%]">

      <!-- Left: headline, top-flush to image top, stretches full image height -->
      <div class="flex-1 flex flex-col justify-between text-center lg:text-left">
        <div class="tracking-tight font-extrabold text-brand-black">
          <p class="text-3xl lg:text-4xl xl:text-5xl leading-tight mb-6">Thinking of Switching?</p>
          <p class="text-3xl lg:text-4xl xl:text-5xl leading-tight">We'll Do the Heavy Lifting.</p>
        </div>
        <!-- Invisible spacer holds bottom flush with image -->
        <div></div>
      </div>

      <!-- Right: photo -->
      <div class="flex-1">
        <Image
          src={bizGuyImage}
          alt="Small business owner — Pink Payroll client"
          width={700}
          format="webp"
          quality={80}
          class="w-full h-full rounded-2xl shadow-lg object-cover"
        />
      </div>

    </div>
  </section>

  <!-- Comparison Grid -->
  <section class="max-w-4xl mx-auto px-6 pt-5 pb-10">

    <!-- Column Headers -->
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-[#231F20] text-white text-center font-extrabold text-sm uppercase tracking-widest py-4 rounded-xl">
        The "Big Box" Struggle
      </div>
      <div class="bg-pink text-white text-center font-extrabold text-sm uppercase tracking-widest py-4 rounded-xl">
        The Pink Payroll Way
      </div>
    </div>

    <!-- Row 1 -->
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 flex gap-4 items-start">
        <span class="text-2xl mt-0.5 flex-shrink-0">😤</span>
        <div>
          <p class="font-bold text-brand-black mb-1">You're Just a Ticket Number.</p>
          <p class="text-brand-gray text-sm leading-relaxed">Waiting on hold for "the next available agent."</p>
        </div>
      </div>
      <div class="bg-pink/5 border border-pink/20 rounded-xl p-6 flex gap-4 items-start">
        <span class="text-2xl mt-0.5 flex-shrink-0">📞</span>
        <div>
          <p class="font-bold text-brand-black mb-1">Direct Access.</p>
          <p class="text-brand-gray text-sm leading-relaxed">A real person who knows your business and picks up the phone.</p>
        </div>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 flex gap-4 items-start">
        <span class="text-2xl mt-0.5 flex-shrink-0">🤷</span>
        <div>
          <p class="font-bold text-brand-black mb-1">"DIY" Guesswork.</p>
          <p class="text-brand-gray text-sm leading-relaxed">Software that lets you process payroll even if something looks "off."</p>
        </div>
      </div>
      <div class="bg-pink/5 border border-pink/20 rounded-xl p-6 flex gap-4 items-start">
        <span class="text-2xl mt-0.5 flex-shrink-0">👀</span>
        <div>
          <p class="font-bold text-brand-black mb-1">Human Oversight.</p>
          <p class="text-brand-gray text-sm leading-relaxed">A second set of eyes to flag the obvious stuff before it's too late.</p>
        </div>
      </div>
    </div>

    <!-- Row 3 -->
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 flex gap-4 items-start">
        <span class="text-2xl mt-0.5 flex-shrink-0">😰</span>
        <div>
          <p class="font-bold text-brand-black mb-1">The Nightmare of Switching.</p>
          <p class="text-brand-gray text-sm leading-relaxed">Worrying about lost data and tax-filing gaps.</p>
        </div>
      </div>
      <div class="bg-pink/5 border border-pink/20 rounded-xl p-6 flex gap-4 items-start">
        <span class="text-2xl mt-0.5 flex-shrink-0">🚀</span>
        <div>
          <p class="font-bold text-brand-black mb-1">We Drive the Transition.</p>
          <p class="text-brand-gray text-sm leading-relaxed">We handle the data migration so you don't have to.</p>
        </div>
      </div>
    </div>

  </section>

  <!-- 15-Min Vibe Check CTA -->
  <section class="bg-[#F5F5F7] mt-5 py-6 px-6 text-center">
    <div class="max-w-2xl mx-auto">

      <!-- "15-Minute Zoom Call" — pink background pill -->
      <div class="inline-flex items-center gap-3 bg-pink text-white rounded-2xl px-8 py-4 mb-6 shadow-sm">
        <span class="text-3xl">📹</span>
        <span class="text-3xl lg:text-4xl font-extrabold tracking-tight">15-Minute Zoom Call</span>
      </div>

      <h2 class="text-3xl font-extrabold text-brand-black mb-4">
        Let's Do a "Vibe Check"
      </h2>
      <p class="text-brand-gray text-lg leading-relaxed mb-8">
        No high-pressure sales pitches. No office visits. Just a quick, casual Zoom call to see if we're the right fit for your business. We'll show you exactly how the 3-month credit works and how we handle the move for you.
      </p>

      <!-- Flash Bonus Box — blue combo -->
      <div class="bg-white border border-[#2B99C5]/40 rounded-2xl px-8 py-6 mb-8 text-left shadow-sm">
        <p class="text-[#2B99C5] font-extrabold uppercase tracking-widest text-xs mb-2">⚡ Flash Bonus</p>
        <p class="text-brand-black font-bold text-lg mb-1">$0 Switching Fees if you book your Zoom call in the next 24 hours.</p>
        <p class="text-brand-gray text-sm leading-relaxed">We do the heavy lifting of loading your data, you keep the money in your pocket. A truly risk-free switch.</p>
      </div>

      <!-- Rocking CTA button + curved arrow -->
      <div class="relative inline-block">
        <a
          href="#calendar"
          class="rock inline-flex items-center justify-center bg-pink text-white font-bold text-lg px-10 py-5 rounded-full hover:bg-[#C62028] transition-colors shadow-md mb-3"
        >
          Grab a 15-Min Spot on the Calendar
        </a>
        <p class="text-brand-gray text-sm mb-4">Get 3 Months Free upon switching</p>

        <!-- Curved arrow pointing down to calendar -->
        <svg
          class="absolute -right-20 top-0 w-20 h-28 text-pink"
          viewBox="0 0 80 110"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <!-- Curved path from top-left sweeping down-right -->
          <path
            d="M10 5 C 50 5, 70 40, 55 95"
            stroke="currentColor"
            stroke-width="3.5"
            stroke-linecap="round"
            fill="none"
          />
          <!-- Arrowhead -->
          <path
            d="M55 95 L 42 80 M 55 95 L 68 82"
            stroke="currentColor"
            stroke-width="3.5"
            stroke-linecap="round"
            fill="none"
          />
        </svg>
      </div>

    </div>
  </section>

  <!-- Calendar — blue banner -->
  <section id="calendar" class="bg-[#2B99C5] py-12 px-6">
    <div class="max-w-md mx-auto rounded-2xl overflow-hidden shadow-lg">
      <iframe src="https://api.leadconnectorhq.com/widget/booking/gZIYVYUm3txLBKTRjTZd" style="width: 100%;border:none;overflow: hidden;" scrolling="no" id="gZIYVYUm3txLBKTRjTZd_1773022815072"></iframe>
      <script src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript" is:inline></script>
    </div>
  </section>

  <!-- Team + Hero Image -->
  <section class="max-w-5xl mx-auto px-6 py-14">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <div class="flex-1 text-center lg:text-left">
        <h2 class="text-3xl font-extrabold text-brand-black mb-5">
          Our Team: Your Personal Payroll Department
        </h2>
        <p class="text-lg text-brand-gray leading-relaxed">
          We are a boutique payroll agency based in San Diego, specializing in high-touch service for California employers. Instead of a revolving door of call center agents, you get direct access to a dedicated leadership team with decades of tax and payroll expertise. We treat your business like our own — providing the human oversight and "second set of eyes" that big-box corporations simply can't offer.
        </p>
      </div>
      <div class="flex-1 w-full">
        <Image
          src={heroImage}
          alt="Pink Payroll — boutique payroll team"
          width={700}
          format="webp"
          quality={80}
          class="w-full h-auto rounded-2xl shadow-lg"
        />
      </div>
    </div>
  </section>

</LandingLayout>
