---
// payroll-exit-guide — Ebook lead capture | Payroll Exit Guide readers
import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="See If Pink Payroll Is Right for Your Business | San Diego Payroll"
  description="Pink Payroll serves a select group of San Diego businesses. Tell us about your payroll situation and we'll reach out within one business day."
  robots="index, follow"
>

  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-6 pt-10 pb-8 text-center">
    <p class="text-xs font-bold uppercase tracking-widest text-[#E7365A] mb-3">
      San Diego's Top-Rated Payroll Company · 18+ Years
    </p>
    <h1 class="text-4xl lg:text-5xl font-extrabold text-brand-black leading-tight mb-5">
      You've Done the Research.<br class="hidden sm:block" /> Now See If We're a Fit.
    </h1>
    <p class="text-lg text-brand-gray leading-relaxed mb-8 max-w-2xl mx-auto">
      Pink Payroll works with a select group of San Diego businesses. Tell us about your situation — we'll take it from there.
    </p>

    <!-- Trust columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10 text-left max-w-4xl mx-auto">

      <div class="text-center">
        <div class="w-14 h-14 rounded-full bg-[#E7365A]/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-[#E7365A]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h3 class="text-lg font-extrabold text-brand-black mb-2">18+ Years in Business</h3>
        <p class="text-brand-gray text-sm leading-relaxed">Serving San Diego businesses since 2008 — through recessions, pandemics, and every California tax change in between.</p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 rounded-full bg-[#E7365A]/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-[#E7365A]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-extrabold text-brand-black mb-2">#1 Rated on Google &amp; Yelp</h3>
        <p class="text-brand-gray text-sm leading-relaxed">More 5-star reviews than any local payroll company. Our clients stay — and they tell their friends.</p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 rounded-full bg-[#E7365A]/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-[#E7365A]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.58 3.38 2 2 0 0 1 3.55 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <h3 class="text-lg font-extrabold text-brand-black mb-2">US-Based, Dedicated Service</h3>
        <p class="text-brand-gray text-sm leading-relaxed">You get a specialist, not a call center queue. One point of contact who knows your account inside and out.</p>
      </div>

    </div>
  </section>

  <!-- Form section -->
  <section class="bg-[#F5F5F7] py-12 px-6">
    <div class="max-w-2xl mx-auto">

      <h2 class="text-2xl font-extrabold text-brand-black mb-2 text-center">Tell Us About Your Business</h2>
      <p class="text-brand-gray text-sm text-center mb-8">We review every submission personally. No spam, ever.</p>

      <!-- GHL Form placeholder — ~20% taller than the existing 800px home-page embed (≈ 960px) -->
      <!-- REPLACE the div below with your GHL form iframe code when ready -->
      <div
        id="ghl-exit-guide-form-placeholder"
        class="w-full bg-white rounded-2xl border-2 border-dashed border-[#E7365A]/40 flex flex-col items-center justify-center text-center px-8 gap-4"
        style="min-height: 960px;"
      >
        <span class="text-5xl">📋</span>
        <p class="font-bold text-brand-black text-lg">GHL Form Embed Goes Here</p>
        <p class="text-brand-gray text-sm max-w-sm">
          Replace this placeholder with the GoHighLevel iframe embed code for the
          <strong>Payroll Exit Guide</strong> intake form. Target iframe height: <strong>960 px</strong>
          (≈ 20% taller than the home-page quote form at 800 px).
        </p>
        <p class="text-xs text-brand-gray/60 mt-2">Fields: employees (dropdown) · current provider · biggest frustration (textarea) · city &amp; state · name / email / phone · timeline (dropdown)</p>
        <p class="text-xs text-brand-gray/60">Submit button: "See If We're a Fit →"</p>
      </div>

      <!-- Thank-you state (hidden by default, shown via JS after submit) -->
      <div id="exit-guide-thankyou" class="hidden w-full bg-white rounded-2xl border border-[#E7365A]/20 shadow-sm px-8 py-12 text-center">
        <div class="text-5xl mb-5">&#10003;</div>
        <h3 class="text-2xl font-extrabold text-brand-black mb-4">Thank You — We'll Be in Touch.</h3>
        <p class="text-brand-gray leading-relaxed mb-6 max-w-lg mx-auto">
          A Pink Payroll specialist will review your information and reach out within one business day.
          We're not a call center — you'll hear from someone who actually knows payroll.
        </p>
        <p class="text-sm text-brand-gray/70">
          Questions in the meantime? <a href="https://pinkpayroll.com" class="text-[#E7365A] font-semibold hover:underline">pinkpayroll.com</a>
        </p>
      </div>

    </div>
  </section>

  <script is:inline>
    // When GHL fires its success event, swap form for thank-you state
    window.addEventListener('message', function(e) {
      if (e.data && e.data.type === 'form_submitted') {
        var placeholder = document.getElementById('ghl-exit-guide-form-placeholder');
        var thanks = document.getElementById('exit-guide-thankyou');
        if (placeholder) placeholder.classList.add('hidden');
        if (thanks) thanks.classList.remove('hidden');
      }
    });
  </script>

</LandingLayout>
