---
import Layout from '../layouts/Layout.astro';
import GHLQuoteForm from '../components/GHLQuoteForm.astro';
import ReviewsHome from '../components/ReviewsHome.astro';
---

<Layout title="Pink Payroll — Payroll Services for California Small Businesses" description="Stop being Account #8492. Pink Payroll gives California small businesses expert payroll service with a dedicated manager who knows your name. Get a free quote today.">

  <!-- Hero Section -->
  <section class="max-w-7xl mx-auto px-6 py-24 flex flex-col lg:flex-row items-center gap-16">
    <div class="flex-1">
      <div class="inline-flex items-center gap-2 bg-pink-light text-pink-dark text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
        &#9733; California Small Business Specialists
      </div>
      <h1 class="text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-brand-black mb-6">
        You're a<br>business owner,<br><span class="whitespace-nowrap">not <span class="text-pink">Account #8492.</span></span>
      </h1>
      <p class="text-xl text-brand-gray max-w-lg mb-10 leading-relaxed">
        Stop crossing your fingers every time you hit "Submit." We handle payroll details and the tax math, so you can just focus on your team.
      </p>
      <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
        <a href="#quote" class="inline-flex items-center justify-center bg-pink text-white font-semibold px-8 py-4 rounded-full hover:bg-pink-dark transition-colors text-base">
          Get Your Price Now
        </a>
        <a href="/contact" class="inline-flex items-center justify-center bg-[#2D2D2D] text-white font-semibold px-8 py-4 rounded-full hover:bg-brand-black transition-colors text-base">
          Get Started
        </a>
      </div>
    </div>

    <!-- Hero Image -->
    <div class="flex-1 w-full">
      <img
        src="/assets/hero-image.png"
        alt="Pink Payroll — boutique payroll services"
        class="w-[90%] h-auto rounded-2xl shadow-lg object-cover"
      />
    </div>

  </section>

  <ReviewsHome />

  {/* Hero Visual Placeholder — hidden until real graphic is ready
    <div class="flex-1 max-w-md w-full bg-brand-light-gray rounded-2xl h-80 flex items-center justify-center text-brand-gray text-sm font-medium">
      Hero Graphic — Coming Soon
    </div>

    Social Proof / Logo Bar — hidden until real client logos are ready
    <div style="background-color:#2D2D2D !important; padding:80px 0 !important;">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-center text-xs font-bold uppercase tracking-widest mb-8" style="color:#FFFFFF !important; letter-spacing:0.12em;">
          Trusted by California businesses across every industry
        </p>
        <div class="flex flex-wrap items-center justify-center gap-5">
          {Array.from({length: 6}).map(() => (
            <div class="w-32 h-12 rounded-lg flex items-center justify-center text-xs font-medium"
                 style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); color:#FFFFFF; filter:brightness(0) invert(1); opacity:0.8;">
              Client Logo
            </div>
          ))}
        </div>
      </div>
    </div>
  */}

  <!-- Reality Check + Get a Quote -->
  <section id="quote" style="background-color:#FFFFFF !important;" class="py-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-0 items-start">

      <!-- Left (40%): Hard Truth copy -->
      <div class="w-full lg:w-[40%]">
        <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">The Hard Truth</p>
        <h2 class="text-4xl font-extrabold tracking-tight leading-tight mb-10 text-[#2D2D2D]">
          Is your current payroll provider a Partner or just a <span class="text-pink">Call Center?</span>
        </h2>
        <div class="flex flex-col gap-4">
          <div class="bg-white border border-brand-light-gray rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-[#2D2D2D] mb-2">The Deadline Panic</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              <strong class="text-[#2D2D2D]">40 minutes to nowhere.</strong> You're stuck on hold while your payroll deadline is ticking. You can't afford to be late.
            </p>
          </div>
          <div class="bg-white border border-brand-light-gray rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-[#2D2D2D] mb-2">The Rep Runaround</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              <strong class="text-[#2D2D2D]">New rep, every time.</strong> You're tired of explaining your business over and over to a stranger reading a script.
            </p>
          </div>
          <div class="bg-white border border-brand-light-gray rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-[#2D2D2D] mb-2">The Black Hole</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              The "Post and Pray." You send an urgent request and hope it actually gets fixed. You deserve <strong class="text-[#2D2D2D]">real answers</strong>, not a prayer.
            </p>
          </div>
        </div>
      </div>

      <!-- Center (15%): breathing room -->
      <div class="hidden lg:block lg:w-[15%]"></div>

      <!-- Right (35%): GHL Quote Form — Pink Box -->
      <div class="w-full lg:w-[35%] mt-12 lg:mt-0">
        <div
          style="background:#E7365A; border-radius:12px; padding:40px; box-shadow:0 8px 32px rgba(0,0,0,0.10);"
        >
          <p class="text-white/80 text-xs font-bold uppercase tracking-widest mb-2 text-center">Get Started</p>
          <h3 class="text-2xl font-extrabold text-center text-white mb-2">Simplified Payroll Starts Here</h3>
          <p class="text-white/80 text-sm text-center mb-6 leading-relaxed">Fast, no-obligation quote — we'll reach out within one business day.</p>
          <GHLQuoteForm />
        </div>
      </div>

    </div>
  </section>

  <!-- Pink Payroll Process -->
  <section id="process" class="bg-gray-50 border-y border-brand-light-gray py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">The Pink Payroll Process</p>
      <h2 class="text-4xl font-extrabold tracking-tight mb-4">High-Tech Simplicity. Human Oversight.</h2>
      <p class="text-brand-gray text-lg max-w-xl mb-14">
        Three steps designed to take payroll completely off your plate — without losing the human touch.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-brand-light-gray">

        <!-- Step 1 -->
        <div class="flex items-start gap-5 py-6 px-4 md:block md:p-8">
          <div class="w-10 h-10 flex-shrink-0 bg-pink rounded-full flex items-center justify-center text-white font-bold text-sm md:mb-5">1</div>
          <div>
            <h3 class="font-bold text-lg mb-2">The 3-Minute Entry</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              Log in, enter your hours, and close. Our platform is built for speed, not for "data entry." It's designed to be the easiest three minutes of your work week — so you can cross payroll off your list and move on.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex items-start gap-5 py-6 px-4 md:block md:p-8">
          <div class="w-10 h-10 flex-shrink-0 bg-pink rounded-full flex items-center justify-center text-white font-bold text-sm md:mb-5">2</div>
          <div>
            <h3 class="font-bold text-lg mb-2">The Expert Safety Net</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              You manage the entry; we manage the accuracy. If you're running tight on a deadline or have a complex question, you don't call a center — you reach out to your dedicated manager. We catch the "weird" stuff before it becomes a problem.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex items-start gap-5 py-6 px-4 md:block md:p-8">
          <div class="w-10 h-10 flex-shrink-0 bg-pink rounded-full flex items-center justify-center text-white font-bold text-sm md:mb-5">3</div>
          <div>
            <h3 class="font-bold text-lg mb-2">Hand-Off the Headache</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              From tax filings to historical data migration, we handle the high-stakes heavy lifting that keeps you up at night. Nearly 18 years of experience, and a team that treats your business like their own.
            </p>
          </div>
        </div>

      </div>

      <!-- Cert Badge -->
      <div class="flex flex-col items-center text-center gap-6 mt-14 pt-12 border-t border-brand-light-gray">
        <img src="/assets/California Payroll Certification Badge 2026-V1.png"
             alt="California Payroll Certification Badge 2026"
             class="h-28 w-auto" />
        <div>
          <h4 class="font-bold text-lg mb-2">California Certified. 18+ Years of Experience.</h4>
          <p class="text-brand-gray text-sm leading-relaxed max-w-2xl">
            Pink Payroll holds current California payroll certification, keeping your business compliant with every state and local requirement — year after year.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Switching Section -->
  <section class="bg-pink-light py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Switching Providers</p>
      <h2 class="text-4xl font-extrabold tracking-tight mb-5">Switching shouldn't be a second job.</h2>
      <p class="text-brand-gray text-lg leading-relaxed mb-10">
        Most business owners stay with a provider they don't like because they dread the migration. We've turned "switching" into a science. From auditing your year-to-date data to verifying your tax history, we handle the heavy lifting so your transition is seamless.
      </p>
      <a href="/switching" class="bg-pink text-white font-semibold px-8 py-4 rounded-full hover:bg-pink-dark transition-colors inline-block">
        See Our Painless Switch Process
      </a>
    </div>
  </section>


  <!-- ===== FOUNDER MESSAGE ===== -->
  <section class="bg-brand-light-gray/40 border-t border-brand-light-gray">
    <div class="max-w-3xl mx-auto px-6 py-20">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-4 text-center">A Message from Our Founder</p>
      <h2 class="text-3xl font-extrabold text-brand-black mb-10 text-center">Why Erica Built This Company</h2>

      <div class="bg-white border-l-4 border-pink rounded-xl shadow-sm p-8 mb-8">
        <blockquote class="text-brand-black text-xl font-semibold leading-relaxed mb-4">
          "If you call your provider, the person who answers should actually have the answer. No transfers, no case numbers — just help."
        </blockquote>
        <figcaption class="text-brand-gray text-sm font-semibold">
          Erica Filippo &mdash; Founder &amp; CEO, Pink Payroll
        </figcaption>
      </div>

      <p class="text-brand-gray text-lg leading-relaxed mb-5">
        Erica Filippo started Pink Payroll after experiencing the same payroll frustrations you face today. She wanted quick answers — but instead was stuck with 50-digit security codes, endless hold music, and "support" reps who didn't know a payroll report from a bowl of spaghetti.
      </p>
      <p class="text-brand-gray leading-relaxed mb-5">
        Erica believed that if you call your provider, the person who answers should actually have the answer. No transfers, no "case numbers," just help.
      </p>
      <p class="text-brand-gray leading-relaxed mb-8">
        Nearly 18 years later, that simple promise is why our very first clients are still with us.
      </p>
      <div class="text-center">
        <a href="/about" class="inline-block bg-pink text-white font-semibold px-8 py-4 rounded-full hover:bg-pink-dark transition-colors text-base">
          Meet the Team &rarr;
        </a>
      </div>
    </div>
  </section>

</Layout>
