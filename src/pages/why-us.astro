---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Why Pink Payroll? The Boutique Advantage — Pink Payroll">

  <!-- ===== HERO ===== -->
  <section class="bg-brand-black text-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-5">Why Pink Payroll</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight max-w-3xl">
        Tired of "Call Center Roulette"?<br class="hidden md:block" />
        <span class="text-pink">Meet Your New Payroll Partner.</span>
      </h1>
      <p class="text-gray-300 text-xl max-w-2xl leading-relaxed">
        After 18 years in California payroll, we know the truth: small businesses don't need more automated menus. They need experts who actually answer the phone.
      </p>
    </div>
  </section>

  <!-- ===== BOUTIQUE ADVANTAGE ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">The Boutique Advantage</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-4">Personal Service. Professional Horsepower.</h2>
      <p class="text-brand-gray text-lg max-w-2xl mx-auto">
        We built Pink Payroll to be the "Anti-Call-Center" choice. We combine the technical power of the industry giants with the white-glove service of a specialized agency.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <div class="border-l-4 border-pink bg-white rounded-xl shadow-sm p-8">
        <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">01</p>
        <h3 class="text-xl font-extrabold text-brand-black mb-3">California-First Expertise</h3>
        <p class="text-xs font-semibold text-brand-gray uppercase tracking-wide mb-3">Your Regulatory Shield</p>
        <p class="text-brand-gray leading-relaxed">
          California labor laws and tax codes are the most complex in the country. We specialize in the "California headache" so you don't have to spend your weekends reading EDD updates. We know the rules so you don't have to.
        </p>
      </div>

      <div class="border-l-4 border-pink bg-white rounded-xl shadow-sm p-8">
        <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">02</p>
        <h3 class="text-xl font-extrabold text-brand-black mb-3">A Dedicated Team, Not a Support Ticket</h3>
        <p class="text-brand-gray leading-relaxed">
          You aren't just an entry in a database. When you have a question, you get a direct line to our expert support team — personally overseen by our senior managers. No generic menus, no waiting for a callback from a stranger.
        </p>
      </div>

      <div class="border-l-4 border-[#C62028] bg-white rounded-xl shadow-sm p-8">
        <p class="text-[#C62028] text-xs font-bold uppercase tracking-widest mb-3">03</p>
        <h3 class="text-xl font-extrabold text-brand-black mb-3">The 3-Minute Payroll Goal</h3>
        <p class="text-brand-gray leading-relaxed">
          Your time belongs to your business, not your payroll data entry. Our systems are optimized to get you in, out, and back to work in 3 minutes or less. We respect your time as much as you do.
        </p>
      </div>

      <div class="border-l-4 border-[#C62028] bg-white rounded-xl shadow-sm p-8">
        <p class="text-[#C62028] text-xs font-bold uppercase tracking-widest mb-3">04</p>
        <h3 class="text-xl font-extrabold text-brand-black mb-3">Total Transparency</h3>
        <p class="text-xs font-semibold text-brand-gray uppercase tracking-wide mb-3">No "Gotcha" Fees</p>
        <p class="text-brand-gray leading-relaxed">
          The big guys love hidden fees and "tier upgrades." We believe in honest, predictable pricing and accurate tax filings every single time.
        </p>
      </div>

    </div>
  </section>

  <!-- ===== COMPARISON TABLE ===== -->
  <section class="bg-brand-light-gray/40 border-y border-brand-light-gray">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="text-center mb-12">
        <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Side by Side</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black">How We Compare</h2>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-brand-light-gray">
              <th class="text-left py-4 pr-6 text-brand-gray font-semibold uppercase tracking-wide text-xs w-1/3">Feature</th>
              <th class="text-left py-4 pr-6 text-brand-gray font-semibold uppercase tracking-wide text-xs w-1/3">Big Box Corporations</th>
              <th class="text-left py-4 text-pink font-semibold uppercase tracking-wide text-xs w-1/3">The Pink Payroll Way</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-light-gray">
            {[
              { feature: 'Support', big: '45-min hold times', pink: 'Direct line to a human' },
              { feature: 'CA Expertise', big: 'Generic / National', pink: 'California Specialists' },
              { feature: 'Onboarding', big: 'Automated / DIY', pink: 'Expert-Led Setup' },
              { feature: 'Relationship', big: "You're a number", pink: "You're a partner" },
            ].map(({ feature, big, pink }) => (
              <tr>
                <td class="py-4 pr-6 font-semibold text-brand-black">{feature}</td>
                <td class="py-4 pr-6 text-brand-gray">{big}</td>
                <td class="py-4 font-bold text-pink">{pink}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== NATIONAL REACH ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-14 items-center">

      <div>
        <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Coverage</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-6">
          San Diego Roots.<br />National Reach.<br />
          <span class="text-pink">All 50 States.</span>
        </h2>
        <p class="text-brand-gray text-lg leading-relaxed mb-5">
          While we are a proud San Diego staple, Pink Payroll is a fully-equipped national provider. We have the technical infrastructure and regulatory expertise to support your employees across all 50 U.S. states.
        </p>
        <p class="text-brand-gray leading-relaxed">
          Whether you are a local shop in La Jolla or a growing company with a distributed team from New York to Florida, you get the same elite level of service. We handle the complex multi-state tax filings so you can hire the best talent, anywhere in the country.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-5">
        {[
          { stat: '50', label: 'U.S. States Supported' },
          { stat: '18+', label: 'Years in California Payroll' },
          { stat: '5.0★', label: 'Average Rating, Google & Yelp' },
          { stat: '100%', label: 'US-Based Team' },
        ].map(({ stat, label }) => (
          <div class="bg-white border border-brand-light-gray rounded-2xl p-6 text-center shadow-sm">
            <p class="text-3xl font-extrabold text-pink mb-2">{stat}</p>
            <p class="text-brand-gray text-xs leading-snug">{label}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ===== TRIBE BUILDING / FIT QUALIFICATION ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Is Pink Payroll Right for You?</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-4">We're Selective — On Purpose.</h2>
      <p class="text-brand-gray text-lg max-w-2xl mx-auto">
        We aren't the right choice for everyone, and we're okay with that. We focus on business owners who value precision over price-shopping.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 items-start">

      <!-- You'll love working with us -->
      <div class="bg-white border border-brand-light-gray rounded-2xl p-8 shadow-sm">
        <h3 class="text-xl font-extrabold text-brand-black mb-6">You'll love working with us if:</h3>
        <ul class="space-y-5">
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-pink flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">You value your time:</strong> You want to hand off the payroll headaches to a pro so you can stay focused on growing your business.
            </p>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-pink flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">You appreciate the "Paper Trail":</strong> You like knowing that every expert answer you get is documented, accurate, and ready for your records.
            </p>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-pink flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">You want a partner, not a vendor:</strong> You're looking for a team that knows your business and will be there for the next ten years, not just the next ten minutes.
            </p>
          </li>
        </ul>
      </div>

      <!-- Probably NOT a fit -->
      <div class="bg-brand-light-gray/50 border border-brand-light-gray rounded-2xl p-8">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full bg-brand-gray inline-block"></span>
          <h3 class="text-xl font-extrabold text-brand-black">We're probably NOT a fit if:</h3>
        </div>
        <ul class="space-y-5">
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-white border border-brand-light-gray flex items-center justify-center">
              <svg class="w-3 h-3 text-brand-gray" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">Your payroll runs on your schedule, not a set one:</strong> We're built for businesses that run payroll consistently — weekly, biweekly, or semimonthly. If your payrolls are seasonal, sporadic, or happen just a few times a year, our structured systems aren't the right fit for where you are right now.
            </p>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-white border border-brand-light-gray flex items-center justify-center">
              <svg class="w-3 h-3 text-brand-gray" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">You prefer the "Big Box" experience:</strong> You're comfortable being Account #8492 and don't mind explaining your situation to a new stranger every time you call.
            </p>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-white border border-brand-light-gray flex items-center justify-center">
              <svg class="w-3 h-3 text-brand-gray" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">You thrive on "cute" chaos:</strong> If you prefer flying by the seat of your pants over a reliable system, our structured workflow might feel too "organized" for you.
            </p>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 w-5 h-5 flex-shrink-0 rounded-full bg-white border border-brand-light-gray flex items-center justify-center">
              <svg class="w-3 h-3 text-brand-gray" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <p class="text-brand-gray leading-relaxed">
              <strong class="text-brand-black">You just want a login, not a relationship:</strong> We provide high-caliber tech, but our real value is the human oversight behind it.
            </p>
          </li>
        </ul>
      </div>

    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="bg-pink text-white">
    <div class="max-w-3xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-4">Experience the Boutique Difference.</h2>
      <p class="text-pink-light text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        Ready to stop being "Account #8472" and start being a partner?
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/book-call" class="bg-white text-pink font-semibold px-8 py-4 rounded-full hover:bg-gray-100 transition-colors text-base">
          Schedule a Consultation
        </a>
        <a href="/contact" class="border-2 border-white/60 text-white font-semibold px-8 py-4 rounded-full hover:border-white hover:bg-white/10 transition-colors text-base">
          Get a Quote
        </a>
      </div>
    </div>
  </section>

</Layout>
