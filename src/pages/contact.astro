---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Pink Payroll">

  <!-- Page Header -->
  <section class="bg-brand-black text-white">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Let's Talk</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight">
        Contact Pink Payroll
      </h1>
    </div>
  </section>

  <!-- Triage: Current Clients | Prospective Clients -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- LEFT: Current Clients -->
      <div class="bg-brand-light-gray/40 border border-brand-light-gray rounded-2xl p-10">
        <div class="w-10 h-10 rounded-full bg-brand-black flex items-center justify-center mb-6">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2h5M12 12a4 4 0 100-8 4 4 0 000 8z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-extrabold mb-4" style="color:#2D2D2D;">Current Clients</h2>
        <p class="text-brand-gray leading-relaxed mb-6">
          Need support? Our team is here to help. Please use one of the following methods to reach us:
        </p>
        <ul class="space-y-5">
          <li class="flex items-start gap-4">
            <button type="button" onclick="window.Beacon('open')" title="Open Help Widget"
              class="flex-shrink-0 w-10 h-10 bg-pink rounded-full flex items-center justify-center text-white hover:bg-pink-dark transition-colors shadow-md">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </button>
            <p class="text-brand-gray text-sm leading-relaxed pt-1">
              <strong class="text-brand-black">Help Widget (Recommended):</strong> Click the icon to submit an email. This is the fastest way to reach our support team.
            </p>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 bg-brand-light-gray rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-gray" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </span>
            <p class="text-brand-gray text-sm leading-relaxed pt-1">
              <strong class="text-brand-black">Phone Support:</strong> Call <a href="tel:8585473599" class="text-pink font-semibold hover:underline">(858) 547-3599</a>. Please listen for the menu prompts to be routed directly to the Processing or Tax departments.
            </p>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 bg-brand-light-gray rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-gray" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            <p class="text-brand-gray text-sm leading-relaxed pt-1">
              <strong class="text-brand-black">Standard Support:</strong> You may continue to use your established support channels to contact us as you normally would.
            </p>
          </li>
        </ul>
      </div>

      <!-- RIGHT: Prospective Clients -->
      <div class="bg-white border border-brand-light-gray rounded-2xl p-10 shadow-sm">
        <div class="w-10 h-10 rounded-full bg-pink flex items-center justify-center mb-6">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-extrabold mb-4" style="color:#2D2D2D;">Prospective Clients</h2>
        <p class="text-brand-gray leading-relaxed mb-8">
          Ready to switch to a boutique payroll experience? Schedule a strategy session with a team leader.
        </p>
        <a href="/book-call" class="inline-block bg-pink text-white font-bold px-8 py-4 rounded-full hover:bg-pink-dark transition-colors text-base">
          Book a Strategy Session
        </a>
      </div>

    </div>
  </section>

  <!-- Map Section -->
  <section class="bg-white py-14 px-6">
    <div class="max-w-7xl mx-auto">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Our Location</p>
      <h2 class="text-2xl font-extrabold text-brand-black mb-6">San Diego Office</h2>
      <iframe
        src="https://maps.google.com/maps?q=4010+Morena+Blvd+%23220+San+Diego+CA+92117&output=embed&z=15"
        width="100%"
        height="400"
        style="border:1px solid #E1E1E1; border-radius:8px; display:block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Pink Payroll — 4010 Morena Blvd #220, San Diego CA 92117"
      ></iframe>
    </div>
  </section>

  <!-- Contact Details Strip -->
  <section class="bg-brand-black text-white py-14 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <!-- Address -->
        <div>
          <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Mailing Address</p>
          <p class="text-gray-300 text-sm leading-relaxed">4079 Governor Drive, #5040<br />San Diego, CA 92122</p>
        </div>

        <!-- Toll Free -->
        <div>
          <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Toll Free</p>
          <a href="tel:8009950308" class="text-white font-semibold text-lg hover:text-pink transition-colors">(800) 995-0308</a>
        </div>

        <!-- San Diego -->
        <div>
          <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">San Diego Office</p>
          <a href="tel:8585473599" class="text-white font-semibold text-lg hover:text-pink transition-colors">(858) 547-3599</a>
        </div>

        <!-- Hours -->
        <div>
          <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Office Hours</p>
          <p class="text-gray-300 text-sm leading-relaxed">Monday – Friday<br />8:30 am – 5:00 pm PST</p>
        </div>

      </div>
    </div>
  </section>

</Layout>
