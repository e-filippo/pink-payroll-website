---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us — Pink Payroll">
  <section class="max-w-5xl mx-auto px-6 py-24">
    <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Get in Touch</p>
    <h1 class="text-5xl font-extrabold tracking-tight text-brand-black mb-6">Contact Us</h1>
    <p class="text-brand-gray text-lg max-w-2xl mb-12">Ready to simplify payroll? Reach out and we'll get back to you within one business day.</p>
    <div class="h-64 bg-gray-100 border border-brand-light-gray rounded-2xl flex items-center justify-center text-brand-gray text-sm">
      Contact form — coming soon
    </div>
  </section>
</Layout>
