---
import Layout from '../layouts/Layout.astro';
import GHLQuoteForm from '../components/GHLQuoteForm.astro';
---

<Layout title="Get a Free Payroll Quote — Pink Payroll" description="Request a fast, no-obligation payroll quote from Pink Payroll. We'll reach out within one business day.">
  <section class="py-16 px-6 bg-white">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-extrabold text-brand-black text-center mb-2">Get Your Free Payroll Quote</h1>
      <p class="text-brand-gray text-center mb-10">Fast, no-obligation — we'll reach out within one business day.</p>
      <GHLQuoteForm />
    </div>
  </section>
</Layout>
