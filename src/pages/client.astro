---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Client Resource Center — Pink Payroll" description="Pink Payroll client resources: access your iSolved payroll portal, download onboarding documents, and get expert support from your dedicated team.">

  <!-- ===== HERO ===== -->
  <section class="bg-brand-black text-white">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-5">Client Portal</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">
        Client Resource Center
      </h1>
      <p class="text-gray-300 text-xl max-w-xl leading-relaxed">
        Everything you need to manage your team and your account — in one place.
      </p>
    </div>
  </section>

  <!-- ===== COMMAND CENTER CARDS ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-1 gap-6 max-w-3xl">

      <!-- Card 1: Payroll Portal -->
      <div class="bg-white border border-brand-light-gray rounded-2xl shadow-sm p-10 flex flex-col sm:flex-row gap-8 items-start">
        <div class="text-5xl flex-shrink-0">🔐</div>
        <div class="flex-1">
          <h2 class="text-2xl font-extrabold text-brand-black mb-3">Payroll Portal Access</h2>
          <p class="text-brand-gray leading-relaxed mb-6">
            Access your full payroll suite, employee records, and tax reporting via our secure iSolved partner portal.
          </p>
          <a
            href="https://llrx.myisolved.com/UserLogin.aspx?ReturnUrl=%2fdefault.aspx"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-pink text-white font-semibold px-6 py-3 rounded-full hover:bg-[#C62028] transition-colors text-sm"
          >
            Login to iSolved Portal
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Card 2: New Client Onboarding -->
      <div class="bg-white border border-brand-light-gray rounded-2xl shadow-sm p-10 flex flex-col sm:flex-row gap-8 items-start">
        <div class="text-5xl flex-shrink-0">📝</div>
        <div class="flex-1">
          <h2 class="text-2xl font-extrabold text-brand-black mb-3">New Client Onboarding</h2>
          <p class="text-brand-gray leading-relaxed mb-6">
            Starting your partnership with Pink Payroll? Download and complete the data form below to begin your white-glove setup.
          </p>
          <a
            href="/new-client-onboarding.pdf"
            download
            class="inline-flex items-center gap-2 bg-brand-black text-white font-semibold px-6 py-3 rounded-full hover:bg-gray-800 transition-colors text-sm"
          >
            Download New Client Data Form
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
          </a>
          <p class="text-brand-gray/60 text-xs mt-3">PDF format</p>
        </div>
      </div>

      <!-- Card 3: Need Assistance -->
      <div class="bg-brand-light-gray/40 border border-brand-light-gray rounded-2xl p-10 flex flex-col sm:flex-row gap-8 items-start">
        <div class="text-5xl flex-shrink-0">🛠️</div>
        <div class="flex-1">
          <h2 class="text-2xl font-extrabold text-brand-black mb-3">Need Assistance?</h2>
          <p class="text-brand-gray leading-relaxed">
            Skip the email and speak directly to our support queue. Click the <strong class="text-brand-black">"Help"</strong> bubble in the bottom right corner of this page to start a ticket or ask a question.
          </p>
        </div>
      </div>

    </div>
  </section>

</Layout>
