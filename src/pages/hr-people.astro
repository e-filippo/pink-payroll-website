---
import Layout from '../layouts/Layout.astro';

const vault = [
  {
    title: 'Custom Employee Handbooks',
    body: 'Regularly updated to reflect the latest state and federal changes — so you never fall behind.',
  },
  {
    title: 'Onboarding Kits',
    body: 'Professional packets that make a great first impression while capturing every required signature.',
  },
  {
    title: 'Performance Management',
    body: 'Documented, legal-ready templates for reviews, warnings, and terminations.',
  },
];

const compliance = [
  {
    title: 'Wage & Hour Audits',
    body: 'Ensuring your staff is correctly classified as Exempt vs. Non-Exempt before it becomes an issue.',
  },
  {
    title: 'Harassment Training',
    body: 'Streamlined, mandated training modules for your entire team — state-compliant and easy to deploy.',
  },
  {
    title: 'Labor Law Posters',
    body: 'Stay compliant with the latest mandatory postings for your job site and remote locations.',
  },
];
---
<Layout title="HR & People — Pink Payroll">

  <!-- ===== HERO ===== -->
  <section class="bg-brand-black text-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <p class="text-[#57AA4C] text-xs font-bold uppercase tracking-widest mb-5">HR & People</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6 max-w-3xl">
        Your California<br class="hidden md:block" />
        <span class="text-[#57AA4C]">Compliance Shield.</span>
      </h1>
      <p class="text-gray-300 text-xl max-w-2xl leading-relaxed">
        In California, HR isn't just about culture — it's about staying out of court. With the most complex labor laws in the country, you need more than a handbook; you need a proactive defense strategy.
      </p>
    </div>
  </section>

  <!-- ===== HR RESOURCE VAULT ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="mb-12">
      <p class="text-[#57AA4C] text-xs font-bold uppercase tracking-widest mb-3">🛡️ Professional HR Support</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-3">Stop Googling Legal Advice.</h2>
      <p class="text-brand-gray text-lg max-w-2xl">
        We provide the tools and expertise to ensure your team is managed professionally and legally.
      </p>
    </div>

    <div class="border-l-4 border-[#57AA4C] pl-6 mb-10">
      <h3 class="text-xl font-extrabold text-brand-black mb-1">The HR Resource Vault</h3>
      <p class="text-brand-gray">Access a comprehensive library of California-specific templates, job descriptions, and policy guides.</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-6">
      {vault.map(({ title, body }) => (
        <div class="bg-white border border-brand-light-gray rounded-2xl shadow-sm p-7 flex flex-col gap-4">
          <span class="w-10 h-10 rounded-xl bg-[#57AA4C]/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[#57AA4C]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
          </span>
          <h3 class="font-extrabold text-brand-black leading-snug">{title}</h3>
          <p class="text-brand-gray text-sm leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== PROACTIVE COMPLIANCE ===== -->
  <section class="bg-brand-light-gray/40 border-y border-brand-light-gray">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="mb-12">
        <p class="text-[#57AA4C] text-xs font-bold uppercase tracking-widest mb-3">⚖️ Proactive Compliance Monitoring</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-3">We Navigate the Minefield Before You Step in It.</h2>
        <p class="text-brand-gray text-lg max-w-2xl">
          California's labor laws change constantly. Our compliance monitoring helps you stay ahead of audits, not react to them.
        </p>
      </div>

      <!-- California Minefield callout -->
      <div class="border-l-4 border-[#C62028] bg-[#C62028]/5 rounded-r-2xl px-7 py-6 mb-10 max-w-2xl">
        <p class="text-[#C62028] text-xs font-bold uppercase tracking-widest mb-2">⚠️ The California Minefield</p>
        <p class="text-brand-gray leading-relaxed">
          California employers face unique exposure on wage claims, meal break violations, and misclassification suits. One audit can cost more than years of professional HR support. We help you navigate it <strong class="text-brand-black">before</strong> an audit happens.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {compliance.map(({ title, body }) => (
          <div class="bg-white border border-brand-light-gray rounded-2xl shadow-sm p-7 flex flex-col gap-4">
            <span class="w-10 h-10 rounded-xl bg-[#57AA4C]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#57AA4C]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <h3 class="font-extrabold text-brand-black leading-snug">{title}</h3>
            <p class="text-brand-gray text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="max-w-3xl mx-auto px-6 py-20 text-center">
    <div class="text-5xl mb-6">🚀</div>
    <p class="text-[#57AA4C] text-xs font-bold uppercase tracking-widest mb-3">Level Up Your Protection</p>
    <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-4">Upgrade to Full HR Support</h2>
    <p class="text-brand-gray text-lg max-w-xl mx-auto mb-10 leading-relaxed">
      Want to move from "Basic Payroll" to "Full HR Support"? We offer scalable HR solutions that grow with your headcount.
    </p>
    <a
      href="/contact"
      class="inline-flex items-center gap-2 bg-[#57AA4C] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#4a9342] transition-colors text-base"
    >
      Request an HR Audit
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
      </svg>
    </a>
  </section>

</Layout>
