---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Loyalty Vault — Pink Payroll">

  <!-- ===== HERO ===== -->
  <section class="bg-brand-black text-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-5">For Our Partners</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6 max-w-3xl">
        The Pink Payroll<br class="hidden md:block" />
        <span class="text-pink">Loyalty Vault.</span>
      </h1>
      <p class="text-gray-300 text-xl max-w-2xl leading-relaxed">
        Our success is built on your loyalty. This vault is our way of saying thank you. We rotate our "Monthly Perks" regularly, ensuring you always have the tools you need to scale.
      </p>
    </div>
  </section>

  <!-- ===== THE BIG ONE ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">🏆 Annual Benefit</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-4">The "Annual Big One"</h2>
      <p class="text-brand-gray text-lg max-w-2xl mx-auto">
        Once per calendar year, every Pink Payroll partner can claim one "Big" service upgrade to supercharge their operations.
      </p>
    </div>

    <p class="text-center text-brand-black font-bold text-lg mb-8">Pick your "Big One" for 2026:</p>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">

      <!-- Option 1: Free Timekeeping -->
      <div class="relative bg-white border-2 border-pink rounded-2xl shadow-md p-8 flex flex-col gap-4">
        <div class="absolute -top-3 left-6">
          <span class="bg-pink text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full">Option A</span>
        </div>
        <div class="text-4xl mt-2">⏱️</div>
        <h3 class="text-xl font-extrabold text-brand-black">4 Months of FREE Timekeeping</h3>
        <p class="text-brand-gray leading-relaxed flex-1">
          Stop the manual entry and try our digital and biometric clocks on us. Zero cost, zero commitment — just better data.
        </p>
        <div class="bg-pink/5 border border-pink/20 rounded-xl px-4 py-3">
          <p class="text-pink font-bold text-sm">Valued at up to $200 — yours free.</p>
        </div>
      </div>

      <!-- Option 2: Free HR Support -->
      <div class="relative bg-white border-2 border-[#57AA4C] rounded-2xl shadow-md p-8 flex flex-col gap-4">
        <div class="absolute -top-3 left-6">
          <span class="bg-[#57AA4C] text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full">Option B</span>
        </div>
        <div class="text-4xl mt-2">🧑‍💼</div>
        <h3 class="text-xl font-extrabold text-brand-black">4 Months of FREE HR Support</h3>
        <p class="text-brand-gray leading-relaxed flex-1">
          Get professional-grade HR tools and templates to protect your team. Handbooks, policies, and expert guidance — covered.
        </p>
        <div class="bg-[#57AA4C]/5 border border-[#57AA4C]/20 rounded-xl px-4 py-3">
          <p class="text-[#57AA4C] font-bold text-sm">Valued at up to $300 — yours free.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ===== MONTHLY PERKS ===== -->
  <section class="bg-brand-light-gray/40 border-y border-brand-light-gray">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="flex flex-col md:flex-row gap-12 items-start max-w-3xl mx-auto">
        <div class="text-5xl flex-shrink-0">🎁</div>
        <div class="flex-1">
          <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Rotating Benefits</p>
          <h2 class="text-3xl font-extrabold text-brand-black mb-4">Monthly Perks & Partner Bonuses</h2>
          <p class="text-brand-gray text-lg leading-relaxed mb-6">
            Check back every month for "Small Wins" — from discount codes for labor law posters to free payroll audits for your secondary LLCs.
          </p>
          <div class="bg-white border border-brand-light-gray rounded-2xl shadow-sm p-6">
            <p class="text-pink text-xs font-bold uppercase tracking-widest mb-2">Current Monthly Perk</p>
            <h3 class="text-lg font-extrabold text-brand-black mb-2">Free 2026 Compliance Checkup</h3>
            <p class="text-brand-gray leading-relaxed text-sm">
              We'll review your current employee files to ensure you're 100% "Audit-Ready" for 2026. No charge, no strings — just peace of mind.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW TO CLAIM ===== -->
  <section class="max-w-5xl mx-auto px-6 py-20 text-center">
    <div class="text-5xl mb-6">🚀</div>
    <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Claiming Is Easy</p>
    <h2 class="text-3xl md:text-4xl font-extrabold text-brand-black mb-4">How to Claim Your Perk</h2>
    <p class="text-brand-gray text-lg max-w-xl mx-auto mb-6 leading-relaxed">
      Ready to activate a bonus? You don't need a coupon code.
    </p>
    <div class="inline-block bg-brand-light-gray/50 border border-brand-light-gray rounded-2xl px-8 py-6 text-left max-w-lg mb-10">
      <p class="text-brand-gray leading-relaxed">
        Just click the <strong class="text-brand-black">"Help"</strong> bubble in the bottom right and tell our payroll team which perk you'd like to claim. We'll handle the rest.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/client" class="inline-flex items-center gap-2 bg-pink text-white font-semibold px-8 py-4 rounded-full hover:bg-[#C62028] transition-colors text-base">
        Go to Client Portal
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
      <a href="/contact" class="inline-flex items-center gap-2 border-2 border-brand-light-gray text-brand-black font-semibold px-8 py-4 rounded-full hover:border-pink hover:text-pink transition-colors text-base">
        Contact Our Team
      </a>
    </div>
  </section>

</Layout>
