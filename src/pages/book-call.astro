---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Book a Call — Pink Payroll">
  <section class="max-w-5xl mx-auto px-6 py-24">
    <p class="text-pink text-xs font-bold uppercase tracking-widest mb-3">Schedule Time</p>
    <h1 class="text-5xl font-extrabold tracking-tight text-brand-black mb-6">Book a Call</h1>
    <p class="text-brand-gray text-lg max-w-2xl mb-12">Schedule a call with our team. Calendar widget coming soon.</p>
    <div class="h-64 bg-gray-100 border border-brand-light-gray rounded-2xl flex items-center justify-center text-brand-gray text-sm">
      Calendar / booking embed — coming soon
    </div>
  </section>
</Layout>
