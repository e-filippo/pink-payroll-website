---
import Layout from '../../../layouts/Layout.astro';

const COMPANY_NAME = "P&J Troy | P&J Magnolia";

// Add new pages here as they are created
const pages = [
  {
    title: "Orientation & Getting Started",
    description: "First steps: software overview, time clocks, fingerprints, and payroll approval.",
    href: "/client-pw/pjcompanies/orientation",
    color: "#E7365A",
    icon: "orientation",
  },
  {
    title: "Timekeeping Instructions",
    description: "How to use your iSolved timekeeping system.",
    href: "/client-pw/pjcompanies/timekeeping",
    color: "#8752A0",
    icon: "clock",
  },
  {
    title: "Payroll Processing Instructions",
    description: "How to process payroll in iSolved.",
    href: "/client-pw/pjcompanies/payroll",
    color: "#C62028",
    icon: "payroll",
  },
];
---

<Layout
  title={`${COMPANY_NAME} — Client Portal | Pink Payroll`}
  description="Private client portal."
  hidePreFooterCTA={true}
  hideBanner={true}
  hideReviewBadge={true}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <!-- Session guard -->
  <script is:inline>
    if (sessionStorage.getItem('auth_pjcompanies') !== 'granted') {
      window.location.replace('/client-pw/pjcompanies/');
    }
  </script>

  <section class="max-w-4xl mx-auto px-6 py-16">

    <!-- Header -->
    <div class="mb-12 border-b border-brand-light-gray pb-8">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-gray mb-2">Private Client Portal</p>
      <h1 class="text-3xl md:text-4xl font-extrabold text-brand-black">{COMPANY_NAME}</h1>
      <p class="text-brand-gray mt-2">Select a topic below to view your instructions.</p>
    </div>

    <!-- Page grid -->
    {pages.length > 0 ? (
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {pages.map((page) => (
          <li>
            <a
              href={page.href}
              class="group flex items-start gap-4 bg-white border border-brand-light-gray rounded-2xl p-6 hover:shadow-md hover:border-transparent transition-all duration-200"
            >
              <!-- Icon -->
              <div
                class="mt-0.5 w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center"
                style={`background-color: ${page.color}18;`}
              >
                {page.icon === 'orientation' && (
                  <svg class="w-5 h-5" style={`color: ${page.color};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                  </svg>
                )}
                {page.icon === 'clock' && (
                  <svg class="w-5 h-5" style={`color: ${page.color};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                )}
                {page.icon === 'payroll' && (
                  <svg class="w-5 h-5" style={`color: ${page.color};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="2" y="5" width="20" height="14" rx="2"/>
                    <path stroke-linecap="round" d="M2 10h20"/>
                    <path stroke-linecap="round" d="M6 15h4M14 15h4"/>
                  </svg>
                )}
              </div>
              <!-- Text -->
              <div>
                <p class="font-bold text-brand-black group-hover:text-pink transition-colors text-base leading-snug">{page.title}</p>
                <p class="text-sm text-brand-gray mt-1">{page.description}</p>
              </div>
              <!-- Arrow -->
              <svg class="ml-auto mt-1 w-4 h-4 text-brand-gray group-hover:text-pink transition-colors flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="text-center text-brand-gray py-20">
        <p class="font-semibold text-brand-black mb-1">No pages yet</p>
        <p class="text-sm">Your Pink Payroll team will add your guides here soon.</p>
      </div>
    )}

    <!-- Logout / start over -->
    <div class="mt-12 text-center">
      <button
        id="logout-btn"
        class="text-xs text-brand-gray hover:text-pink transition-colors underline underline-offset-4"
      >
        Sign out of this session
      </button>
    </div>

  </section>

</Layout>

<script is:inline>
  document.getElementById('logout-btn').addEventListener('click', function () {
    sessionStorage.removeItem('auth_pjcompanies');
    window.location.replace('/client-pw/pjcompanies/');
  });
</script>
