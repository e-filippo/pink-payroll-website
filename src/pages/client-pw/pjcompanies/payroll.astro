---
import Layout from '../../../layouts/Layout.astro';

const docs = [
  {
    title: "How Do I Process a Payroll?",
    description: "Step-by-step guide to processing payroll in iSolved.",
    href: "https://drive.google.com/file/d/1zuct7h8lSyA-bMxS73ixRXBXognF_b5X/view?usp=sharing",
  },
];
---

<Layout
  title="Payroll Processing Instructions — P&J Troy | Pink Payroll"
  description="Private payroll processing instructions for P&J Troy."
  hidePreFooterCTA={true}
  hideBanner={true}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <!-- Auth check — redirect to gate if not authenticated -->
  <script is:inline>
    const SESSION_KEY = 'auth_pjcompanies';
    if (sessionStorage.getItem(SESSION_KEY) !== 'granted') {
      window.location.replace('/client-pw/pjcompanies/');
    }
  </script>

  <div class="max-w-4xl mx-auto px-6 py-14">

    <!-- Back link -->
    <a href="/client-pw/pjcompanies/portal" class="inline-flex items-center gap-1.5 text-xs text-brand-gray hover:text-pink transition-colors mb-10">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      P&amp;J Troy | P&amp;J Magnolia — Client Home
    </a>

    <!-- Page header -->
    <div class="mb-12">
      <span class="inline-block bg-[#C62028]/10 text-[#C62028] text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-3">
        Payroll
      </span>
      <h1 class="text-3xl md:text-4xl font-extrabold text-brand-black leading-tight mb-3">
        Payroll Processing Instructions
      </h1>
      <p class="text-brand-gray text-lg">
        Reference guides for processing payroll in iSolved.
      </p>
    </div>

    <!-- Documents -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-8 rounded-lg bg-[#C62028]/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-[#C62028]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-brand-black">Documents &amp; Guides</h2>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {docs.map((doc) => (
          <li>
            <a
              href={doc.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start gap-4 bg-white border border-brand-light-gray rounded-2xl p-5 hover:shadow-md hover:border-[#C62028]/30 transition-all duration-200 h-full"
            >
              <div class="mt-0.5 w-9 h-9 rounded-lg bg-[#C62028]/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#C62028]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-brand-black group-hover:text-[#C62028] transition-colors text-sm leading-snug mb-1">{doc.title}</p>
                <p class="text-xs text-brand-gray leading-relaxed">{doc.description}</p>
              </div>
              <svg class="w-3.5 h-3.5 text-brand-gray group-hover:text-[#C62028] transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Help callout -->
    <div class="mt-14 bg-brand-light-gray/50 border border-brand-light-gray rounded-2xl px-6 py-6 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="w-10 h-10 rounded-full bg-pink/10 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-pink" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-brand-black text-sm mb-0.5">Need help?</p>
        <p class="text-sm text-brand-gray leading-relaxed">Email your Pink Payroll team at <a href="mailto:payroll@pinkpayroll.com" class="text-pink font-semibold hover:underline">payroll@pinkpayroll.com</a> so we can evaluate the best response. Sometimes we prefer an email back with images and instructions or a video, as that can be more easily implemented than a verbal. Thank you.</p>
      </div>
    </div>

  </div>

</Layout>
