---
import Layout from '../../../layouts/Layout.astro';

const COMPANY_NAME = "P&J Troy";
---

<Layout
  title={`${COMPANY_NAME} — Private Client Access | Pink Payroll`}
  description="Private client access page."
  hidePreFooterCTA={true}
  hideBanner={true}
  hideReviewBadge={true}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <section class="min-h-[70vh] flex items-center justify-center bg-brand-light-gray/40 py-20 px-6">
    <div class="w-full max-w-md">

      <!-- Card -->
      <div class="bg-white rounded-2xl shadow-lg border border-brand-light-gray px-8 py-10 text-center">

        <!-- Lock icon -->
        <div class="w-14 h-14 rounded-full bg-pink/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-7 h-7 text-pink" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>

        <!-- Company name -->
        <h1 class="text-2xl font-extrabold text-brand-black mb-1">{COMPANY_NAME}</h1>
        <p class="text-brand-gray font-medium text-sm mb-8">Private Client Access</p>

        <!-- Password form -->
        <form id="pw-form" novalidate>
          <label for="pw-input" class="block text-left text-xs font-semibold text-brand-black uppercase tracking-wider mb-2">
            Client ID (last 4 digits)
          </label>
          <input
            id="pw-input"
            type="password"
            inputmode="numeric"
            maxlength="4"
            placeholder="e.g. 1234"
            autocomplete="off"
            class="w-full border border-brand-light-gray rounded-xl px-4 py-3 text-lg text-center tracking-[0.3em] font-bold text-brand-black focus:outline-none focus:ring-2 focus:ring-pink focus:border-transparent transition mb-3"
          />
          <p id="pw-error" class="hidden text-red-600 text-xs font-medium mb-3">
            Incorrect ID. Please check your iSolved login and try again.
          </p>
          <button
            type="submit"
            class="w-full bg-pink text-white font-bold py-3.5 rounded-full hover:bg-[#C62028] transition-colors text-sm"
          >
            Access My Page
          </button>
        </form>

        <!-- Explainer -->
        <p class="text-xs text-brand-gray mt-6 leading-relaxed">
          Enter the last 4 digits of your software client ID.<br />
          Your client ID is on your iSolved login page and starts with <strong>PK-#######</strong>.
        </p>

      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  const SESSION_KEY = 'auth_pjcompanies';
  const VALID_PASSWORDS = ['1262', '1263'];
  const DEFAULT_REDIRECT = '/client-pw/pjcompanies/portal';

  // If already authenticated, skip the gate
  if (sessionStorage.getItem(SESSION_KEY) === 'granted') {
    window.location.replace(DEFAULT_REDIRECT);
  }

  document.getElementById('pw-form').addEventListener('submit', function (e) {
    e.preventDefault();
    const input = document.getElementById('pw-input').value.trim();
    const error = document.getElementById('pw-error');

    if (VALID_PASSWORDS.includes(input)) {
      sessionStorage.setItem(SESSION_KEY, 'granted');
      window.location.replace(DEFAULT_REDIRECT);
    } else {
      error.classList.remove('hidden');
      document.getElementById('pw-input').value = '';
      document.getElementById('pw-input').focus();
    }
  });

  // Clear error on new input
  document.getElementById('pw-input').addEventListener('input', function () {
    document.getElementById('pw-error').classList.add('hidden');
  });
</script>
