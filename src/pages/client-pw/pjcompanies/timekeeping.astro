---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Timekeeping Instructions — P&J Troy | Pink Payroll"
  description="Private timekeeping instructions for P&J Troy."
  hidePreFooterCTA={true}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <!-- Auth check runs before anything renders -->
  <script is:inline>
    const SESSION_KEY = 'auth_pjcompanies';
    if (sessionStorage.getItem(SESSION_KEY) !== 'granted') {
      window.location.replace('/client-pw/pjcompanies/');
    }
  </script>

  <section class="max-w-3xl mx-auto px-6 py-16">

    <!-- Breadcrumb / back link -->
    <a href="/client-pw/pjcompanies/portal" class="inline-flex items-center gap-1.5 text-xs text-brand-gray hover:text-pink transition-colors mb-8">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      P&amp;J Troy — Client Home
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <span class="inline-block bg-[#8752A0]/10 text-[#8752A0] text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-3">
        Timekeeping
      </span>
      <h1 class="text-3xl md:text-4xl font-extrabold text-brand-black leading-tight mb-3">
        Timekeeping Instructions
      </h1>
      <p class="text-brand-gray text-lg">
        Step-by-step guidance for P&amp;J Troy team members.
      </p>
    </div>

    <!-- Placeholder content — replace with actual instructions -->
    <div class="prose prose-gray max-w-none">
      <div class="bg-brand-light-gray/50 border border-brand-light-gray rounded-2xl p-8 text-center text-brand-gray">
        <svg class="w-10 h-10 mx-auto mb-3 text-brand-light-gray" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
        </svg>
        <p class="font-semibold text-brand-black mb-1">Instructions coming soon</p>
        <p class="text-sm">Your Pink Payroll team will add your timekeeping guide here. Questions? Call us at <a href="tel:8009950308" class="text-pink hover:underline">(800) 995-0308</a>.</p>
      </div>
    </div>

  </section>

</Layout>
