---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Pink Payroll delivers boutique payroll services for California small businesses.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/branding/pinkpayroll favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- HelpScout Beacon -->
    <script type="text/javascript" is:inline>!function(e,t,n){function a(){var e=t.getElementsByTagName("script")[0],n=t.createElement("script");n.type="text/javascript",n.async=!0,n.src="https://beacon-v2.helpscout.net",e.parentNode.insertBefore(n,e)}if(e.Beacon=n=function(t,n,a){e.Beacon.readyQueue.push({method:t,options:n,data:a})},n.readyQueue=[],"complete"===t.readyState)return a();e.attachEvent?e.attachEvent("onload",a):e.addEventListener("load",a,!1)}(window,document,window.Beacon||function(){});</script>
    <script type="text/javascript" is:inline>window.Beacon('init', '988a061c-4c82-4448-a4e1-c01d728865f1')</script>
  </head>
  <body class="font-sans text-brand-black bg-white antialiased">

    <!-- Minimal header: logo only, no nav -->
    <header class="border-b border-brand-light-gray py-3 px-6">
      <div class="max-w-7xl mx-auto">
        <a href="/">
          <img src="/branding/pinkpayroll standard logo rectangle.png" alt="Pink Payroll" class="h-10 w-auto" />
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Minimal footer: contact info + required compliance links -->
    <footer class="border-t border-brand-light-gray py-10 px-6 text-center text-sm text-brand-gray">
      <p class="font-semibold text-brand-black mb-1">Pink Payroll</p>
      <p>4079 Governor Drive, #5040, San Diego, CA 92122</p>
      <p class="mt-1">(800) 995-0308 &nbsp;|&nbsp; (858) 547-3599</p>
      <div class="flex justify-center gap-3 mt-4">
        <a href="https://facebook.com/pinkpayrollusa" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-8 h-8 rounded bg-gray-200 flex items-center justify-center hover:bg-[#E7365A] hover:text-white transition-colors text-gray-500">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://instagram.com/pinkpayrollusa" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-8 h-8 rounded bg-gray-200 flex items-center justify-center hover:bg-[#E7365A] hover:text-white transition-colors text-gray-500">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://x.com/pinkpayroll" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="w-8 h-8 rounded bg-gray-200 flex items-center justify-center hover:bg-[#E7365A] hover:text-white transition-colors text-gray-500">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/pinkpayroll/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-8 h-8 rounded bg-gray-200 flex items-center justify-center hover:bg-[#E7365A] hover:text-white transition-colors text-gray-500">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://www.pinterest.com/PinkPayroll/" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="w-8 h-8 rounded bg-gray-200 flex items-center justify-center hover:bg-[#E7365A] hover:text-white transition-colors text-gray-500">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
      </div>
      <div class="flex justify-center gap-6 mt-4 text-xs">
        <a href="/privacy-policy" class="hover:text-brand-black transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="hover:text-brand-black transition-colors">Terms of Service</a>
      </div>
      <p class="mt-3 text-xs text-brand-gray/60">&copy; 2026 Pink Payroll. All rights reserved.</p>
    </footer>

  </body>
</html>
