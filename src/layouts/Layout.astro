---
import '../styles/global.css';
import ReviewBadge from '../components/ReviewBadge.astro';

interface Props {
  title: string;
  description?: string;
  hideEmailCTA?: boolean;
  hidePreFooterCTA?: boolean;
}

const { title, description = 'Pink Payroll delivers boutique payroll services for California small businesses. Expert-led, compliant, and personal — we know your name, not just your account number.', hideEmailCTA = false, hidePreFooterCTA = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://pinkpayroll.com');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/branding/pinkpayroll-favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- HelpScout Beacon -->
    <script type="text/javascript" is:inline>!function(e,t,n){function a(){var e=t.getElementsByTagName("script")[0],n=t.createElement("script");n.type="text/javascript",n.async=!0,n.src="https://beacon-v2.helpscout.net",e.parentNode.insertBefore(n,e)}if(e.Beacon=n=function(t,n,a){e.Beacon.readyQueue.push({method:t,options:n,data:a})},n.readyQueue=[],"complete"===t.readyState)return a();e.attachEvent?e.attachEvent("onload",a):e.addEventListener("load",a,!1)}(window,document,window.Beacon||function(){});</script>
    <script type="text/javascript" is:inline>window.Beacon('init', '988a061c-4c82-4448-a4e1-c01d728865f1')</script>
  </head>
  <body class="font-sans text-brand-black bg-white antialiased">

    <!-- Top Banner -->
    <div class="bg-pink text-white py-2 px-4">

      <!-- Mobile: single offer only -->
      <div class="flex md:hidden items-center justify-center gap-2 text-[11px] font-medium text-center">
        <span>New Clients: <strong>3 Months FREE</strong> or <strong>30% OFF!</strong></span>
        <a href="/contact" class="inline-flex items-center justify-center bg-white text-pink font-bold px-3 py-0.5 rounded-full text-[11px] hover:bg-gray-100 transition-colors flex-shrink-0">Get Started</a>
      </div>

      <!-- Desktop: both offers -->
      <div class="hidden md:flex max-w-7xl mx-auto items-center justify-center gap-x-6 text-xs">
        <span class="whitespace-nowrap">
          New Clients: <strong>3 Months FREE</strong> or <strong>30% OFF</strong> — You Decide!&nbsp;
          <a href="/contact" class="inline-flex items-center justify-center bg-white text-pink font-bold px-3 py-0.5 rounded-full text-xs hover:bg-gray-100 transition-colors ml-1">Get Started</a>
        </span>
        <!-- LOYALTY BONUS BANNER — saved for future use, re-enable when ready
        <span class="text-white/50">|</span>
        <span class="whitespace-nowrap">
          Current Clients:&nbsp;
          <a href="/loyalty" class="inline-flex items-center justify-center border border-white/70 text-white font-bold px-3 py-0.5 rounded-full text-xs hover:bg-white/10 transition-colors">Claim Your Loyalty Bonus</a>
        </span>
        -->
      </div>

    </div>

    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-brand-light-gray">
      <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between h-[72px]">

        <!-- Logo -->
        <a href="/" class="flex-shrink-0">
          <img src="/branding/pinkpayroll standard logo rectangle.png" alt="Pink Payroll" class="h-14 w-auto" />
        </a>

        <!-- Desktop Primary Nav -->
        <ul class="hidden lg:flex items-center gap-7 text-sm font-medium text-brand-gray">
          <li>
            <a href="/why-us" class="hover:text-pink transition-colors">Why Us?</a>
          </li>

          <!-- Our Services Dropdown -->
          <li class="relative group">
            <button class="flex items-center gap-1 hover:text-pink transition-colors py-2">
              Our Services
              <svg class="w-3.5 h-3.5 mt-px" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul class="absolute left-0 top-full mt-1 w-60 bg-white border border-brand-light-gray rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-1">
              <li><a href="/payroll"        class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Payroll Services</a></li>
              <li><a href="/software-demos" class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Payroll Software &amp; Demos</a></li>
              <li><a href="/timekeeping"    class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Timekeeping</a></li>
              <li><a href="/workers-comp"   class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Workers Comp Insurance</a></li>
              <li><a href="/hr-people"      class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">HR | People</a></li>
            </ul>
          </li>

          <!-- Discover Dropdown -->
          <li class="relative group">
            <button class="flex items-center gap-1 hover:text-pink transition-colors py-2">
              Discover
              <svg class="w-3.5 h-3.5 mt-px" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul class="absolute left-0 top-full mt-1 w-60 bg-white border border-brand-light-gray rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-1">
              <li><a href="/switching" class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">How to Switch</a></li>
              <li><a href="/learn"     class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Learn About Payroll</a></li>
              <li><a href="/who"       class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Who We Serve</a></li>
              <li><a href="/client"    class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Client Resources</a></li>
              <li><a href="/employee"  class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Employee Resources</a></li>
              <li><a href="/partners"  class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Partners &amp; Affiliates</a></li>
              <li><a href="/about"     class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Meet the Team</a></li>
            </ul>
          </li>

          <li><a href="/contact" class="hover:text-pink transition-colors">Contact Us</a></li>
          <li>
            <a href="/book-call" class="inline-flex items-center justify-center bg-pink text-white font-bold text-sm px-5 py-2.5 rounded-full hover:bg-[#C62028] transition-colors">
              Book a Call
            </a>
          </li>
        </ul>

        <!-- Desktop Right: Login + Phone + CTA -->
        <div class="hidden lg:flex items-center gap-4">
          <!-- Client Login Dropdown -->
          <div class="relative group">
            <button class="text-sm font-medium text-brand-gray hover:text-pink flex items-center gap-1 transition-colors py-2">
              Client Login
              <svg class="w-3.5 h-3.5 mt-px" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul class="absolute right-0 top-full mt-1 w-52 bg-white border border-brand-light-gray rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-1">
              <li><a href="https://payrollrx.myisolved.com/UserLogin.aspx" target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">Payroll Software</a></li>
              <li><a href="/client-set-up" class="block px-4 py-2.5 text-sm text-brand-black hover:bg-gray-50 hover:text-pink transition-colors">New Client Setup</a></li>
            </ul>
          </div>
          <a href="tel:8009950308" class="hidden xl:flex items-center gap-1.5 text-sm font-semibold text-brand-black hover:text-pink transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 12.9a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            (800) 995-0308
          </a>
          <a href="/client-set-up" class="inline-flex items-center justify-center bg-pink text-white text-sm font-bold px-5 py-2.5 rounded-full hover:bg-[#C62028] transition-colors">
            Onboard Now
          </a>
        </div>

        <!-- Mobile: Phone + Hamburger -->
        <div class="flex lg:hidden items-center gap-3">
          <a href="tel:8009950308" aria-label="Call us" class="flex items-center justify-center w-10 h-10 rounded-full text-brand-black hover:text-pink transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 12.9a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </a>
          <button id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false"
            class="flex items-center justify-center w-10 h-10 rounded-lg text-brand-black hover:bg-gray-100 transition-colors">
            <svg id="icon-hamburger" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

      </nav>

      <!-- Mobile Menu Panel -->
      <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-brand-light-gray overflow-y-auto max-h-[80vh]">
        <div class="px-6 py-5 space-y-1">

          <!-- Top CTAs -->
          <div class="flex flex-col gap-3 pb-4 mb-2 border-b border-brand-light-gray">
            <a href="/book-call" class="block text-center bg-pink text-white font-bold px-6 py-3.5 rounded-full hover:bg-[#C62028] transition-colors text-sm">
              Book a Call
            </a>
            <a href="/contact" class="block text-center bg-gray-100 text-brand-black font-semibold px-6 py-3.5 rounded-full hover:bg-brand-light-gray transition-colors text-sm">
              Get Started
            </a>
          </div>

          <!-- Main Links -->
          <a href="/why-us"  class="block py-3 text-brand-black font-semibold hover:text-pink transition-colors border-b border-gray-50">Why Us?</a>
          <a href="/contact" class="block py-3 text-brand-black font-semibold hover:text-pink transition-colors border-b border-gray-50">Contact Us</a>

          <!-- Our Services -->
          <p class="text-xs font-bold uppercase tracking-widest text-brand-gray pt-4 pb-1">Our Services</p>
          <a href="/payroll"        class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Payroll Services</a>
          <a href="/software-demos" class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Payroll Software &amp; Demos</a>
          <a href="/timekeeping"    class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Timekeeping</a>
          <a href="/workers-comp"   class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Workers Comp Insurance</a>
          <a href="/hr-people"      class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">HR | People</a>

          <!-- Discover -->
          <p class="text-xs font-bold uppercase tracking-widest text-brand-gray pt-4 pb-1">Discover</p>
          <a href="/switching" class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">How to Switch</a>
          <a href="/learn"     class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Learn About Payroll</a>
          <a href="/who"       class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Who We Serve</a>
          <a href="/about"     class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Meet the Team</a>

          <!-- Resources -->
          <p class="text-xs font-bold uppercase tracking-widest text-brand-gray pt-4 pb-1">Resources</p>
          <a href="/client-set-up" class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">New Client Setup</a>
          <a href="/client"    class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Client Resources</a>
          <a href="/employee"  class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Employee Resources</a>
          <a href="/partners"  class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Partners &amp; Affiliates</a>
          <a href="https://payrollrx.myisolved.com/UserLogin.aspx" target="_blank" rel="noopener noreferrer"
             class="block py-2.5 pl-3 text-sm text-brand-black hover:text-pink transition-colors">Client Login ↗</a>

          <!-- Click-to-Call -->
          <div class="pt-4 pb-2 border-t border-brand-light-gray mt-3 space-y-2">
            <a href="tel:8009950308" class="flex items-center gap-3 py-2.5 text-brand-black font-semibold hover:text-pink transition-colors">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 12.9a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (800) 995-0308 <span class="text-xs text-brand-gray font-normal">Toll Free</span>
            </a>
            <a href="tel:8585473599" class="flex items-center gap-3 py-2.5 text-brand-black font-semibold hover:text-pink transition-colors">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.19 12.9a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (858) 547-3599 <span class="text-xs text-brand-gray font-normal">San Diego</span>
            </a>
          </div>

        </div>
      </div>

      <!-- Mobile Menu Toggle Script -->
      <script is:inline>
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const iconOpen = document.getElementById('icon-hamburger');
        const iconClose = document.getElementById('icon-close');
        btn.addEventListener('click', () => {
          const isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden', isOpen);
          iconOpen.classList.toggle('hidden', !isOpen);
          iconClose.classList.toggle('hidden', isOpen);
          btn.setAttribute('aria-expanded', String(!isOpen));
        });
        // Close menu when a link is tapped
        menu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            menu.classList.add('hidden');
            iconOpen.classList.remove('hidden');
            iconClose.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      </script>

    </header>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Pre-Footer CTA -->
    {!hidePreFooterCTA && (
    <section class="bg-brand-light-gray/50 border-t border-brand-light-gray">
      <div class="max-w-3xl mx-auto px-6 py-16 text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold text-brand-black mb-3 leading-tight">
          Ready to Scale with a Partner Who Knows Your Name?
        </h2>
        <p class="text-brand-gray text-lg mb-8 leading-relaxed">
          Stop settling for Big Box frustration. Let's build your compliance roadmap today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="https://link.pinkpayroll.com/widget/booking/gZIYVYUm3txLBKTRjTZd" target="_blank" rel="noopener noreferrer" class="bg-pink text-white font-bold px-8 py-4 rounded-full hover:bg-[#C62028] transition-colors text-base">
            Schedule Your Discovery Call
          </a>
          {!hideEmailCTA && (
            <button type="button" onclick="window.Beacon('navigate', '/ask')" class="text-brand-gray text-sm hover:text-pink transition-colors underline underline-offset-4">
              Prefer to email? Click here.
            </button>
          )}
        </div>
      </div>
    </section>
    )}

    <!-- Footer -->
    <footer class="bg-brand-black text-gray-400">
      <div class="max-w-7xl mx-auto px-6 py-14">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-10 border-b border-gray-700">

          <!-- Brand -->
          <div>
            <img src="/branding/pinkpayroll logo dark rectangle.png" alt="Pink Payroll" class="h-10 w-auto mb-4" />
            <p class="text-sm leading-relaxed mb-5">Professional payroll services for California small businesses.</p>
            <div class="space-y-1.5 text-sm mb-5">
              <p class="text-gray-400"><span class="font-semibold text-gray-300">Mailing Address:</span> 4079 Governor Drive, #5040</p>
              <p class="text-gray-400">San Diego, CA 92122</p>
              <a href="https://maps.google.com/?q=4010+Morena+Blvd+%23220,+San+Diego,+CA+92117"
                 target="_blank" rel="noopener noreferrer"
                 class="text-pink text-xs hover:text-white transition-colors mt-1 inline-block">
                View on Google Maps ↗
              </a>
              <p class="mt-3">
                <a href="tel:8009950308" class="text-pink hover:text-white transition-colors font-semibold">(800) 995-0308</a>
                <span class="text-gray-600 ml-1 text-xs">Toll Free</span>
              </p>
              <p>
                <a href="tel:8585473599" class="text-pink hover:text-white transition-colors font-semibold">(858) 547-3599</a>
                <span class="text-gray-600 ml-1 text-xs">San Diego</span>
              </p>
              <p class="text-gray-500 text-xs pt-1">Mon – Fri &nbsp;8:30 am – 5:00 pm PST</p>
            </div>
            <div class="flex gap-3">
              <a href="https://www.facebook.com/pinkpayroll" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center hover:bg-pink hover:text-white transition-colors text-gray-300">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
              <a href="https://instagram.com/pinkpayrollusa" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center hover:bg-pink hover:text-white transition-colors text-gray-300">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
              <a href="https://x.com/pinkpayroll" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center hover:bg-pink hover:text-white transition-colors text-gray-300">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://www.linkedin.com/company/pinkpayroll/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center hover:bg-pink hover:text-white transition-colors text-gray-300">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
